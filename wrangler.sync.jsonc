{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "worldcup-sync-worker",
  "main": "worker/sync-worker.js",
  "compatibility_date": "2026-06-18",
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "worldcup-case-base",
