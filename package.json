{
  "scripts": {
    "verify:production-baseline": "node tools/check-production-baseline.mjs",
    "dev": "node server.mjs",
    "sporttery:fetch": "node tools/fetch-sporttery-live.mjs && node tools/fetch-sporttery-results.mjs && node tools/fetch-sporttery-sp-history.mjs && node tools/fetch-live-football-scores.mjs",
    "case-base:generate": "node tools/generate-case-base.mjs",
    "league-profiles:generate": "node tools/generate-league-profiles.mjs",
    "history:import-api": "node tools/import-free-history-api.mjs",
    "history:import-api-football": "node tools/import-api-football-history.mjs",
    "history:import-football-data": "node tools/import-football-data-history.mjs",
    "history:export-d1": "node tools/export-external-history-d1-sql.mjs",
    "history:import-footiqo": "node tools/import-footiqo-history.mjs",
    "live-scores:fetch": "node tools/fetch-live-football-scores.mjs",
    "sporttery:auto-deploy": "node tools/auto-update-and-deploy.mjs",
    "cloudflare:login": "node scripts/cloudflare-pages.mjs login",
    "cloudflare:whoami": "node scripts/cloudflare-pages.mjs whoami",
    "cloudflare:deploy": "npm run verify:production-baseline && node scripts/cloudflare-pages.mjs deploy",
    "deploy:pages": "npm run verify:production-baseline && node scripts/cloudflare-pages.mjs deploy",
    "d1:migrate": "wrangler d1 execute worldcup-case-base --file migrations/0001_case_base_schema.sql --remote",
    "d1:migrate:upgrade-notes": "wrangler d1 execute worldcup-case-base --file migrations/0003_model_upgrade_notes.sql --remote",
    "d1:migrate:external-history": "wrangler d1 execute worldcup-case-base --file migrations/0004_external_historical_samples.sql --remote",
    "api:health": "curl -s https://worldcup-dashboard-4hr.pages.dev/api/health"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "dependencies": {}
}
